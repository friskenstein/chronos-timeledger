{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://chronos-timeledger/contracts/schemas/ledger-header.schema.json",
	"title": "Chronos Ledger Header",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schema_version",
		"created_at",
		"projects",
		"tasks",
		"categories"
	],
	"properties": {
		"schema_version": {
			"type": "integer",
			"const": 1,
			"minimum": 1
		},
		"created_at": {
			"type": "string",
			"format": "date-time"
		},
		"day_start_offset_hours": {
			"type": "integer",
			"default": 0
		},
		"projects": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/project"
			}
		},
		"tasks": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/task"
			}
		},
		"categories": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/category"
			}
		}
	},
	"$defs": {
		"id": {
			"type": "string",
			"pattern": "^[A-Za-z0-9]{8}$"
		},
		"project": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"name",
				"archived"
			],
			"properties": {
				"id": {
					"$ref": "#/$defs/id"
				},
				"name": {
					"type": "string",
					"minLength": 1
				},
				"color": {
					"type": [
						"string",
						"null"
					]
				},
				"archived": {
					"type": "boolean"
				}
			}
		},
		"task": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"project_id",
				"description",
				"archived"
			],
			"properties": {
				"id": {
					"$ref": "#/$defs/id"
				},
				"project_id": {
					"$ref": "#/$defs/id"
				},
				"category_id": {
					"type": [
						"string",
						"null"
					],
					"pattern": "^[A-Za-z0-9]{8}$"
				},
				"description": {
					"type": "string",
					"minLength": 1
				},
				"archived": {
					"type": "boolean"
				}
			}
		},
		"category": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"name",
				"archived"
			],
			"properties": {
				"id": {
					"$ref": "#/$defs/id"
				},
				"name": {
					"type": "string",
					"minLength": 1
				},
				"description": {
					"type": [
						"string",
						"null"
					]
				},
				"archived": {
					"type": "boolean"
				}
			}
		}
	}
}
